{
  "info": {
    "_postman_id": "8932a4a3-bc88-4c59-a5f3-c08c888e26dc",
    "name": "Onde Driver API",
    "description": "Collection para gestão de drivers",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "14578781"
  },
  "item": [
    {
      "name": "Get Drivers",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "ae191560-2482-4745-b082-82ed4e3ee931",
              "type": "string"
            }
          ]
        },
        "method": "GET",
